{
  "name": "myartelab",
  "version": "1.0.0",
  "description": "Built for African Creators. Trusted by clients globally.",
  "main": "backend/frontend/index.html",
  "scripts": {
    "dev:frontend": "cd backend/frontend/app && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:clean": "cd backend && npm run dev:clean",
    "kill-port": "cd backend && npm run kill-port",
    "build:frontend": "cd backend/frontend/app && npm run build && cp -r dist/* .. && cp -r dist/assets ..",
    "start": "cd backend/frontend && python3 -m http.server 8000",
    "open": "xdg-open http://localhost:8000 || firefox http://localhost:8000",
    "test": "cd backend && npm test",
    "deploy:build": "cd backend/frontend/app && npm install && npm run build && cp -r dist/* .. && cp -r dist/assets .. && cp -r ../app-images/* ../images/ 2>/dev/null || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Japhetjohn/my-arte-lab.app.git"
  },
  "keywords": [
    "marketplace",
    "creators",
    "booking",
    "portfolio",
    "react",
    "typescript",
    "vite"
  ],
  "author": "Japhetjohn",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Japhetjohn/my-arte-lab.app/issues"
  },
  "homepage": "https://github.com/Japhetjohn/my-arte-lab.app#readme"
}
